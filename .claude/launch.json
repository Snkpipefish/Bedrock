{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web-static",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8124", "--directory", "web"],
      "port": 8124
    },
    {
      "name": "signal-server",
      "runtimeExecutable": ".venv/bin/flask",
      "runtimeArgs": [
        "--app", "bedrock.signal_server:create_app()",
        "run",
        "--port", "8125",
        "--no-debugger",
        "--no-reload"
      ],
      "port": 8125,
      "env": {
        "PYTHONPATH": "src"
      }
    }
  ]
}
