# Kopier til ~/.bedrock/secrets.env og fyll inn ekte verdier.
# ALDRI commit .env-filen.

# ── Fetch-API-er ────────────────────────────────────────────
FRED_API_KEY=
TWELVEDATA_API_KEY=
FINNHUB_API_KEY=
BEDROCK_NASS_API_KEY=             # USDA NASS QuickStats — gratis, registrer på https://quickstats.nass.usda.gov/api
BEDROCK_EIA_API_KEY=              # EIA Open Data — gratis, registrer på https://www.eia.gov/opendata/register.php

# ── Signal-server ───────────────────────────────────────────
SCALP_API_KEY=                  # felles mellom push_signals, signal_server, bot
FLASK_URL=http://localhost:5000
FLASK_PORT=5000

# ── Admin-kode for UI + rule-editor ────────────────────────
# SHA-256 hash av admin-koden, ikke klartekst
ADMIN_CODE_HASH=

# ── Varsling (valgfritt) ────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK=

# ── Bot (cTrader Open API) ──────────────────────────────────
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_ACCOUNT_ID_DEMO=
CTRADER_ACCOUNT_ID_LIVE=

# ── Publisering ─────────────────────────────────────────────
PUSH_MAX_SIGNALS=10

# ── Modus ───────────────────────────────────────────────────
BEDROCK_ENV=development          # development | staging | production
BEDROCK_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
