# Auto-generert av `bedrock systemd generate`.
# Ikke rediger manuelt — kjør CLI-kommandoen på nytt hvis config endrer seg.
[Unit]
Description=Bedrock fetch timer: cot_legacy
Requires=bedrock-fetch-cot_legacy.service

[Timer]
OnCalendar=Fri *-*-* 22:00:00
Persistent=true
Unit=bedrock-fetch-cot_legacy.service

[Install]
WantedBy=timers.target
