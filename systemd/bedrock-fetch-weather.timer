# Auto-generert av `bedrock systemd generate`.
# Ikke rediger manuelt — kjør CLI-kommandoen på nytt hvis config endrer seg.
[Unit]
Description=Bedrock fetch timer: weather
Requires=bedrock-fetch-weather.service

[Timer]
OnCalendar=*-*-* 03:00:00
Persistent=true
Unit=bedrock-fetch-weather.service

[Install]
WantedBy=timers.target
