# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
dist/
build/

# Virtual env
.venv/
.venv-*/
venv/

# UV
.uv-cache/

# IDE
.vscode/
.idea/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Hemmeligheter — aldri commit
.env
*.env
.env.local
secrets/
~/.bedrock/

# Logger og lokale data-filer som vokser
logs/
*.log
data/parquet/**/*.parquet
data/latest/*.json
data/setups/active.json
data/_meta/*.json
data/_meta/compare_*.md
data/signal_log.json

# Bedrock-bot runtime state (sub-fase 12.9 D5+): trade-log, daily-loss-
# state, agri-symbol-info skrives av boten. Persisteres i fil for review,
# men ikke kildekontrollert.
data/bot/signal_log.json
data/bot/trade_log.jsonl
data/bot/daily_loss_state.json
data/bot/agri_symbol_info.json
data/bot/*.tmp
data/bot/confirmation_stats.json

# Sub-fase 12.11+: signals_bot.json regenereres av hver fetcher's
# ExecStartPost (signals-all). Kildekontrollering forårsaker konstante
# auto-push-konflikter når laptop ligger bak origin.
data/signals_bot.json
data/signals.json
data/agri_signals.json

# Men behold mappene (via .gitkeep) + baseline-filer
!data/parquet/.gitkeep
!data/latest/.gitkeep
!data/setups/.gitkeep
!data/_meta/.gitkeep
!data/_meta/*_baseline_*.json
!data/_meta/*_baseline_*.md
!data/bot/.gitkeep

# Test-artefakter
tests/**/coverage.xml
tests/**/htmlcov/
.coverage
.coverage.*

# DuckDB working files
*.duckdb
*.duckdb.wal
data/bedrock.db
data/*.db

# Genererte systemd-unit-filer (lokal-spesifikke paths; re-genererbare
# via `bedrock systemd generate`)
systemd/bedrock-fetch-*.service
systemd/bedrock-fetch-*.timer

# Volatil signal-output (regeneres av orchestrator)
data/signals.json
data/agri_signals.json

# Tier 2 backfill runtime files
data/_meta/tier2_backfill.pid
data/_meta/tier2_backfill.log

# Manuelt nedlastede kilder (store filer, ikke checkes inn)
bedrock manuell data/
data/_meta/backfill_*.pid
data/_meta/backfill_*.log

# Lokale backfill-PDFer (lastet ned via Wayback, ikke distribusjonsklare)
data/manual/unica_archive/
